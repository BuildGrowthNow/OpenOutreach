#!/bin/bash
# compose/start - Start nginx, Next.js, VNC, and Django

set -o errexit
set -o pipefail
set -o nounset

# Virtual display (always needed — Playwright launches headed mode)
rm -f /tmp/.X99-lock
Xvfb :99 -screen 0 1920x1080x24 &
sleep 1
export DISPLAY=:99

# Ensure nginx directories exist with proper permissions (must be root)
mkdir -p /var/lib/nginx/body /var/lib/nginx/proxy /var/cache/nginx /run/nginx
chmod 755 /var/lib/nginx /var/cache/nginx /run/nginx

# Start nginx for frontend (Next.js) on port 3000
# nginx must start as ROOT to bind to ports and create PID file
if [ "${SKIP_DAEMON:-false}" = "true" ]; then
    # When SKIP_DAEMON is true, nginx needs to run in background so Django can start
    nginx -g 'daemon on; error_log /dev/stdout warn;'
else
    # Normal mode: run nginx in foreground
    nginx -g 'daemon off;'
fi
sleep 1
NGINX_PID=$(cat /run/nginx/nginx.pid 2>/dev/null || pgrep -x nginx | head -1)

# Check if nginx is running
if ! pgrep -x nginx > /dev/null; then
    echo "ERROR: nginx failed to start"
    nginx -t
    exit 1
fi

echo "nginx started successfully (PID: $NGINX_PID)"

# VNC remote access (only for open-source local use)
if [ "${ENABLE_VNC:-false}" = "true" ]; then
    x11vnc -display :99 -forever -shared -nopw &
    websockify --web /opt/noVNC 6080 localhost:5900 &
fi

# Wait for nginx to be ready
sleep 2

# If SKIP_DAEMON is set, run migrations and Django in background
if [ "${SKIP_DAEMON:-false}" = "true" ]; then
    echo "SKIP_DAEMON=true - Starting Django admin without daemon..."
    gosu ubuntu python manage.py migrate --no-input
    gosu ubuntu python manage.py runserver 0.0.0.0:8000 &
    DJANGO_PID=$!
    echo "Django started with PID $DJANGO_PID"
    # Wait for nginx to be running by polling its PID file
    while [ -f /run/nginx/nginx.pid ] && kill -0 $(cat /run/nginx/nginx.pid) 2>/dev/null; do
        sleep 5
    done
    echo "Nginx stopped, shutting down Django..."
    kill $DJANGO_PID 2>/dev/null || true
    exit 0
fi

# Run the daemon (migrate + onboard + task queue).
# Forward any arguments, e.g. --onboard <file>.
exec gosu ubuntu python manage.py rundaemon "$@"
