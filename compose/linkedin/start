#!/bin/bash
# compose/start - Start Next.js and Django (no container nginx)

# Don't use errexit - let the script continue even if individual commands fail
set -o pipefail
set -o nounset

# Virtual display (always needed — Playwright launches headed mode)
rm -f /tmp/.X99-lock
Xvfb :99 -screen 0 1920x1080x24 &
sleep 1
export DISPLAY=:99

# Start Next.js frontend server on port 3000 (nginx is not used in container)
echo "Starting Next.js server on port 3000..."
if [ -d /app/frontend ]; then
    cd /app/frontend
    gosu ubuntu node_modules/.bin/next start -p 3000 &
    NEXTJS_PID=$!
    echo "Next.js started with PID $NEXTJS_PID"
    cd /app
    
    # Wait for Next.js to be ready (up to 30 seconds)
    echo "Waiting for Next.js to be ready..."
    for i in $(seq 1 30); do
        # Check if Next.js process is running and listening on port 3000
        if ss -tlnp 2>/dev/null | grep -q ":3000"; then
            echo "Next.js is ready and listening on port 3000!"
            break
        fi
        if [ $i -eq 30 ]; then
            echo "ERROR: Next.js failed to start within 30 seconds"
            exit 1
        fi
        sleep 1
    done
else
    echo "ERROR: /app/frontend directory not found"
    NEXTJS_PID=""
fi

# VNC remote access (only for open-source local use)
if [ "${ENABLE_VNC:-false}" = "true" ]; then
    x11vnc -display :99 -forever -shared -nopw &
    websockify --web /opt/noVNC 6080 localhost:5900 &
fi

# Wait for Next.js to be ready
sleep 2

# If SKIP_DAEMON is set, run migrations and Django in background
if [ "${SKIP_DAEMON:-false}" = "true" ]; then
    echo "SKIP_DAEMON=true - Starting Django admin without daemon..."
    gosu ubuntu python manage.py migrate --no-input
    gosu ubuntu python manage.py runserver 0.0.0.0:8000 &
    DJANGO_PID=$!
    echo "Django started with PID $DJANGO_PID"
    # Keep running as long as Next.js is alive
    while kill -0 $NEXTJS_PID 2>/dev/null; do
        sleep 5
    done
    echo "Next.js stopped, shutting down Django..."
    kill $DJANGO_PID 2>/dev/null || true
    exit 0
fi

# Run the daemon (migrate + onboard + task queue).
# Forward any arguments, e.g. --onboard <file>.
exec gosu ubuntu python manage.py rundaemon "$@"