# =============================================================================
# OpenOutreach Django Settings Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values for the specific environment
# =============================================================================

# =============================================================================
# Secret Key (Required)
# =============================================================================
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))'
DJANGO_SECRET_KEY=your-very-secure-secret-key-at-least-50-chars-here

# =============================================================================
# Allowed Hosts (Required for staging/production)
# =============================================================================
# Comma-separated list of allowed hostnames
# Development: localhost,127.0.0.1
# Staging: staging.openoutreach.com,staging-api.openoutreach.com
# Production: openoutreach.com,www.openoutreach.com,api.openoutreach.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# CORS Allowed Origins (Required for staging/production)
# =============================================================================
# Comma-separated list of allowed CORS origins
# Development: *
# Staging: https://staging.openoutreach.com,https://staging-api.openoutreach.com
# Production: https://openoutreach.com,https://www.openoutreach.com
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# =============================================================================
# Database Configuration
# =============================================================================
# For development (SQLite - default)
# DATABASE_NAME, DATABASE_USER, etc. not needed

# For staging/production (PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_NAME=openoutreach
DATABASE_USER=openoutreach
DATABASE_PASSWORD=openoutreach_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_SSLMODE=require

# =============================================================================
# Supabase Configuration (Required for authentication)
# =============================================================================
# Get these from your Supabase project settings at https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-key-here

# =============================================================================
# Email Configuration
# =============================================================================
# SMTP settings for email sending
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_DEFAULT_FROM_EMAIL=noreply@localhost

# =============================================================================
# MongoDB Configuration (Optional)
# =============================================================================
# Set MONGODB_ENABLED=true to use MongoDB instead of SQLite
MONGODB_ENABLED=false
MONGODB_NAME=openoutreach
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=

# =============================================================================
# Security Settings (Production)
# =============================================================================
# These are enabled automatically in production.py when DEBUG=False
# SECURE_SSL_REDIRECT=true
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=true