# OpenOutreach Configuration for LenGrowth
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required for AI-powered outreach)
# =============================================================================
# Choose one provider and configure:
#
# OpenAI (recommended for best quality)
LLM_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4o

# Or use Anthropic (Claude)
# LLM_API_KEY=sk-ant-api01-your-claude-api-key-here
# AI_MODEL=claude-3-5-sonnet-20240620

# Or use an OpenAI-compatible endpoint (AWS Bedrock)
LLM_API_KEY=your-aws-bedrock-api-key-here
LLM_API_BASE=https://bedrock-mantle.us-east-1.api.aws/v1
AI_MODEL=qwen.qwen3-coder-next

# =============================================================================
# LinkedIn Account Credentials (Required)
# =============================================================================
# Your LinkedIn login email/phone
LINKEDIN_USERNAME=your-email@example.com

# Your LinkedIn password
# WARNING: This is stored in plain text. Use environment variables in production.
LINKEDIN_PASSWORD=your-password-here

# =============================================================================
# LinkedIn Profile Settings (Optional - defaults to empty)
# =============================================================================
# Your LinkedIn username (without @ symbol)
# LINKEDIN_PROFILE_USERNAME=

# Your current outreach campaign name
# LINKEDIN_PROFILE_CAMPAIGN=

# =============================================================================
# Optional: BetterContact Email Finder (for enrichment)
# =============================================================================
# Get a key at https://bettercontact.com
FINDER_API_KEY=your-bettercontact-api-key-here

# =============================================================================
# Optional: PostgreSQL Database (for production)
# =============================================================================
# For local development, SQLite is used by default
# Uncomment and configure for production use
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# Optional: Security Settings
# =============================================================================
# Change this from the default in production
SECRET_KEY=your-django-secret-key-at-least-50-chars-here

# =============================================================================
# Rate Limits (Optional - defaults provided)
# =============================================================================
# Number of connection requests per day
CONNECT_DAILY_LIMIT=20

# Number of follow-up messages per day
FOLLOW_UP_DAILY_LIMIT=25

# Maximum actions per time period (velocity)
VELOCITY=20

# Minutes between actions (cooldown)
COOLDOWN_MINUTES=0

# =============================================================================
# Time Zone
# =============================================================================
# Use IANA timezone format
TIME_ZONE=America/New_York

# =============================================================================
# Note: LinkedIn credentials are encrypted using a key derived from SECRET_KEY
# (using PBKDF2 with a fixed salt). Do NOT expose SECRET_KEY in production.
# =============================================================================

# =============================================================================
# VNC Settings (Optional - for LinkedIn browser automation)
# =============================================================================
# Port where VNC server runs
VNC_PORT=5900

# Port where noVNC web interface runs
NOVNC_PORT=6080

# =============================================================================
# MongoDB Configuration (Optional - for production)
# =============================================================================
# Set MONGODB_ENABLED=true to use MongoDB instead of SQLite
# 
# Option 1: MongoDB Atlas (Cloud)
# MONGODB_ENABLED=true
# MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/openoutreach?retryWrites=true&w=majority

# =============================================================================
# AWS/Production Environment Settings
# =============================================================================
# For production deployments, set these environment variables:

# DJANGO_SECRET_KEY=your-very-secure-secret-key-at-least-50-chars
#   (Generate with: python -c 'import secrets; print(secrets.token_urlsafe(50))')

# DJANGO_ALLOWED_HOSTS=your-production-domain.com,www.your-production-domain.com
#   (Comma-separated list of allowed domains)

# DJANGO_CORS_ALLOWED_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com
#   (Comma-separated list of allowed CORS origins)

# DJANGO_EMAIL_HOST=smtp.your-domain.com
#   (SMTP server for emails)

# DJANGO_EMAIL_PORT=587
#   (SMTP port)

# DJANGO_EMAIL_USE_TLS=true
#   (Use TLS for SMTP)

# DJANGO_EMAIL_HOST_USER=your-email@your-domain.com
#   (SMTP username)

# DJANGO_EMAIL_HOST_PASSWORD=your-smtp-password
#   (SMTP password)

# DJANGO_DEFAULT_FROM_EMAIL=noreply@your-production-domain.com
#   (Default from email address)

# DJANGO_ENV=production
#   (Set to 'production' for production environment)

# SENTRY_DSN=https://your-dsn@sentry.io/project
#   (Optional: Sentry error tracking DSN)

# =============================================================================
# Supabase Configuration (Required for authentication)
# =============================================================================
# Get these from your Supabase project settings at https://app.supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# The service key is used for server-side operations (server-to-server)
SUPABASE_SERVICE_KEY=your-service-key-here

# =============================================================================
# Django Environment Settings
# =============================================================================
# Debug mode (set to false in production)
DEBUG=false

# ALLOWED_HOSTS for production
ALLOWED_HOSTS=your-domain.com,localhost,127.0.0.1
