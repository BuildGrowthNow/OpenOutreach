# OpenOutreach Configuration for LenGrowth
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required for AI-powered outreach)
# =============================================================================
# Choose one provider and configure:
#
# OpenAI (recommended for best quality)
LLM_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4o

# Or use Anthropic (Claude)
# LLM_API_KEY=sk-ant-api01-your-claude-api-key-here
# AI_MODEL=claude-3-5-sonnet-20240620

# Or use an OpenAI-compatible endpoint (AWS Bedrock)
LLM_API_KEY=your-aws-bedrock-api-key-here
LLM_API_BASE=https://bedrock-mantle.us-east-1.api.aws/v1
AI_MODEL=qwen.qwen3-coder-next

# =============================================================================
# LinkedIn Account Credentials (Required)
# =============================================================================
# Your LinkedIn login email/phone
LINKEDIN_USERNAME=your-email@example.com

# Your LinkedIn password
# WARNING: This is stored in plain text. Use environment variables in production.
LINKEDIN_PASSWORD=your-password-here

# =============================================================================
# Optional: BetterContact Email Finder (for enrichment)
# =============================================================================
# Get a key at https://bettercontact.com
FINDER_API_KEY=your-bettercontact-api-key-here

# =============================================================================
# Optional: PostgreSQL Database (for production)
# =============================================================================
# For local development, SQLite is used by default
# Uncomment and configure for production use
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# =============================================================================
# Optional: Security Settings
# =============================================================================
# Change this from the default in production
SECRET_KEY=your-django-secret-key-at-least-50-chars-here

# =============================================================================
# Rate Limits (Optional - defaults provided)
# =============================================================================
# Number of connection requests per day
CONNECT_DAILY_LIMIT=20

# Number of follow-up messages per day
FOLLOW_UP_DAILY_LIMIT=25

# =============================================================================
# Time Zone
# =============================================================================
# Use IANA timezone format
TIME_ZONE=America/New_York

# =============================================================================
# Frontend (noVNC) Settings
# =============================================================================
# Port where VNC server runs
VNC_PORT=5900

# Port where noVNC web interface runs
NOVNC_PORT=6080